<Window x:Class="CyberBotSA_part2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot SA - Cybersecurity Awareness Assistant"
        Height="700" Width="900"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Background="#16213e" Margin="0,0,0,5">
            <TextBlock Text="🛡 CYBERBOT SA" 
                       FontSize="28" FontWeight="Bold"
                       Foreground="#00d4ff"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,5"/>
            <TextBlock Text="Your Cybersecurity Awareness Assistant"
                       FontSize="14"
                       Foreground="#a0a0a0"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>
            <TextBlock x:Name="AsciiArt"
                       FontFamily="Courier New"
                       FontSize="8"
                       Foreground="#00d4ff"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"
                       Text="██████╗██╗   ██╗██████╗ ███████╗██████╗     ██████╗  ██████╗ ████████╗&#xa; ██╔════╝╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗    ██╔══██╗██╔═══██╗╚══██╔══╝&#xa; ██║      ╚████╔╝ ██████╔╝█████╗  ██████╔╝    ██████╔╝██║   ██║   ██║&#xa; ██║       ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗    ██╔══██╗██║   ██║   ██║&#xa; ╚██████╗   ██║   ██████╔╝███████╗██║  ██║    ██████╔╝╚██████╔╝   ██║&#xa;  ╚═════╝   ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝   ╚═════╝  ╚═════╝    ╚═╝"/>
        </StackPanel>

        <!-- User name bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" 
                    Background="#0f3460" Margin="0,0,0,5" 
                    Height="40">
            <TextBlock x:Name="UserNameLabel"
                       Text="👤 Not logged in"
                       Foreground="#00d4ff"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="15,0,0,0"/>
            <TextBlock x:Name="FavTopicLabel"
                       Text=""
                       Foreground="#a0a0a0"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Chat area -->
        <ScrollViewer Grid.Row="2" 
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      Margin="10,5,10,5"
                      Background="#16213e">
            <StackPanel x:Name="ChatPanel" Margin="10"/>
        </ScrollViewer>

        <!-- Input area -->
        <Grid Grid.Row="3" Background="#16213e" Margin="10,5,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput"
                     Grid.Column="0"
                     Height="45"
                     FontSize="14"
                     Background="#0f3460"
                     Foreground="White"
                     CaretBrush="White"
                     BorderBrush="#00d4ff"
                     BorderThickness="2"
                     Padding="10,5"
                     VerticalContentAlignment="Center"
                     KeyDown="UserInput_KeyDown"/>

            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="Send"
                    Width="80" Height="45"
                    Margin="5,0,0,0"
                    Background="#00d4ff"
                    Foreground="#1a1a2e"
                    FontWeight="Bold"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SendButton_Click"/>

            <Button x:Name="ClearButton"
                    Grid.Column="2"
                    Content="Clear"
                    Width="80" Height="45"
                    Margin="5,0,0,0"
                    Background="#e94560"
                    Foreground="White"
                    FontWeight="Bold"
                    FontSize="14"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ClearButton_Click"/>
        </Grid>
    </Grid>
    </Window>
